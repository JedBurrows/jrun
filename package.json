{
  "name": "jrun",
  "version": "0.2.0",
  "description": "CLI for running Java projects with process management",
  "type": "module",
  "bin": {
    "jrun": "./bin/jrun"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:sea": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/main.cjs",
    "dev": "tsx src/main.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "effect": "^3.20.0",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@effect/vitest": "latest",
    "@types/react": "^19.2.14",
    "esbuild": "^0.27.4",
    "postject": "^1.0.0-alpha.6",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "msgpackr-extract"
    ]
  }
}
